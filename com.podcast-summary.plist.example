<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.podcast-summary</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3.11</string>
        <string>main.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/oishifamily/Projects/podcast 自動解説/backend</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>GEMINI_API_KEY</key>
        <string>YOUR_GEMINI_API_KEY_HERE</string>
        <key>DISCORD_WEBHOOK_URL</key>
        <string>YOUR_DISCORD_WEBHOOK_URL_HERE</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/oishifamily/Projects/podcast 自動解説/data/server.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/oishifamily/Projects/podcast 自動解説/data/server_error.log</string>
</dict>
</plist>
